# .env.example — Parkshare
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS commiter le fichier .env dans le repo

# ── APPLICATION ──
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production        # development | production

# ── BASE DE DONNÉES ──
DB_PATH=./app/parkshare.duckdb

# ── CHEMINS DONNÉES ──
CSV_PATH=./data/processed/communes_scored.csv
GEOJSON_PATH=./data/processed/communes_scored.geojson

# ── SÉCURITÉ ──
SECRET_KEY=changeme_mettre_une_vraie_clé_secrète_ici

# ── REVERSE PROXY (Nginx / Traefik) ──
DOMAIN=votre-domaine.com
